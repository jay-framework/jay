name: InnerBlock
props:
  - name: label
    type: string
    required: true
tags:
  - tag: blockLabel
    type: data
    dataType: string
    phase: slow

  - tag: widgetValue
    type: data
    dataType: number
    phase: fast+interactive

  - tag: widgetIncrement
    type: interactive
    elementType: HTMLButtonElement
