name: TestWidget
props:
  - name: itemId
    type: string
    required: true
tags:
  - tag: label
    type: data
    dataType: string
    phase: slow
    description: Widget label derived from itemId

  - tag: value
    type: data
    dataType: number
    phase: fast+interactive
    description: Counter value

  - tag: increment
    type: interactive
    elementType: HTMLButtonElement
    description: Increment button
