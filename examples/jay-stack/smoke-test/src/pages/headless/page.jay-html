<html>
<head>
  <script type="application/jay-headless"
          plugin="test-plugin"
          contract="test-widget"></script>
  <script type="application/jay-data">
    data:
  </script>
</head>
<body>
  <div>
    <h1>Headless Test</h1>
    <jay:test-widget itemId="alpha">
      <div class="widget">
        <span class="widget-label">{label}</span>
        <span class="widget-value">{value}</span>
        <button ref="increment">+1</button>
      </div>
    </jay:test-widget>
  </div>
</body>
</html>
