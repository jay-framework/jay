<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-data">
        data:
            products:
                - id: string
                  name: string
                  price: number
    </script>
</head>
<body>
    <ul>
        <li forEach="products" trackBy="id" slow>
            <span class="name">{name}</span>
            <span class="price">{price}</span>
        </li>
    </ul>
</body>
</html>
