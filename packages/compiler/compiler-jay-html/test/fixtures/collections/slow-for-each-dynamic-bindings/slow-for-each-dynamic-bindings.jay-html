<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-data">
        data:
            categories:
                - categoryId: string
                  categoryName: string
                  isSelected: boolean
    </script>
</head>
<body>
    <div class="filter-categories">
        <label class="chip {isSelected ? selected}" forEach="categories" trackBy="categoryId" slow><input type="checkbox" ref="categories.isSelected" /> {categoryName}</label>
    </div>
</body>
</html>
