<html>
<head>
    <script type="application/jay-headless"
            plugin="test-product-card"
            contract="product-card"></script>
    <script type="application/jay-data">
data:
    pageTitle: string
    showPromo: boolean
    products:
        - _id: string
    </script>
</head>
<body>
<div>
    <h1>{pageTitle}</h1>
    <jay:product-card productId="123" ref="hero">
        <article class="hero-card">
            <h2>Hero Product</h2>
            <span class="price">{price}</span>
            <button ref="addToCart">Add to Cart</button>
        </article>
    </jay:product-card>
    <jay:product-card productId="prod-promo" ref="promo" if="showPromo">
        <div class="promo">
            <h3>Promo Product</h3>
            <span class="price">{price}</span>
        </div>
    </jay:product-card>
    <div class="grid">
        <div slowForEach="products" trackBy="_id" jayIndex="0" jayTrackBy="p1">
            <jay:product-card productId="prod-a" ref="0">
                <article class="card-a">
                    <h2>Product A</h2>
                    <span class="price">{price}</span>
                    <button ref="addToCart">Add to Cart</button>
                </article>
            </jay:product-card>
        </div>
        <div slowForEach="products" trackBy="_id" jayIndex="1" jayTrackBy="p2">
            <jay:product-card productId="prod-b" ref="0">
                <article class="card-b">
                    <h3>Product B</h3>
                    <span class="price">{price}</span>
                </article>
            </jay:product-card>
        </div>
    </div>
</div>
</body>
</html>
