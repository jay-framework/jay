<html>
<head>
    <script type="application/jay-headless"
            plugin="test-word-split"
            contract="word-split"></script>
    <script type="application/jay-data">
data:
    title: string
    </script>
</head>
<body>
<div>
    <h1>{title}</h1>
    <jay:word-split text="{title}">
        <span forEach="words" trackBy="index" class="word">{text}</span>
    </jay:word-split>
</div>
</body>
</html>
