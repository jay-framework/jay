<html>
<head>
    <script type="application/jay-data">
data:
    pageTitle: string
    products:
        - _id: string
    </script>
</head>
<body>
<div>
    <h1>{pageTitle}</h1>
    <div class="grid">
        <div slowForEach="products" trackBy="_id" jayIndex="0" jayTrackBy="p1">
            <span>Static Item A</span>
        </div>
        <div slowForEach="products" trackBy="_id" jayIndex="1" jayTrackBy="p2">
            <span>Static Item B</span>
        </div>
    </div>
</div>
</body>
</html>
