<html>
<head>
    <script type="application/jay-data">
data:
    title: string
    visible: boolean
    items:
    -   label: string
        id: string
    </script>
</head>
<body>
<div>
    <h1>{title}</h1>
    <p if="visible">Visible content</p>
    <span style="color: red;">Static</span>
    <ul>
        <li forEach="items" trackBy="id">{label}</li>
    </ul>
</div>
</body>
</html>
