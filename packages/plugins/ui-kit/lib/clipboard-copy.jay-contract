name: clipboard-copy
props:
  - name: text
    kind: required
tags:
  - tag: text
    type: data
    dataType: string
    phase: fast+interactive
    description: Text to copy (from props)

  - tag: copied
    type: data
    dataType: boolean
    phase: fast+interactive
    description: True for a short period after copying

  - tag: copyBtn
    type: interactive
    elementType: HTMLButtonElement
    description: Button that triggers the copy
