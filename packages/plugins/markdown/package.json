{
  "name": "@jay-framework/markdown",
  "version": "0.21.0",
  "type": "module",
  "description": "Markdown rendering plugin for Jay Framework — pages from directories, inline content, code highlighting, mermaid diagrams",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "files": [
    "dist",
    "plugin.yaml",
    "agent-kit"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/index.client.js",
    "./plugin.yaml": "./plugin.yaml",
    "./markdown-pages.jay-contract": "./dist/markdown-pages.jay-contract",
    "./markdown-content.jay-contract": "./dist/markdown-content.jay-contract",
    "./markdown-live.jay-contract": "./dist/markdown-live.jay-contract",
    "./themes/markdown-default.css": "./lib/themes/markdown-default.css",
    "./themes/markdown-docs.css": "./lib/themes/markdown-docs.css",
    "./themes/markdown-blog.css": "./lib/themes/markdown-blog.css"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server && npm run build:copy-assets && npm run build:types",
    "build:client": "vite build",
    "build:server": "vite build --ssr",
    "build:copy-assets": "cp lib/*.jay-contract* dist/",
    "build:types": "tsup lib/index.ts --dts-only --format esm",
    "build:check-types": "tsc",
    "validate": "jay-stack-cli validate-plugin",
    "clean": "rimraf dist",
    "confirm": "npm run clean && npm run build && npm run build:check-types && npm run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@jay-framework/component": "workspace:^",
    "@jay-framework/fullstack-component": "workspace:^",
    "@jay-framework/reactive": "workspace:^",
    "@jay-framework/runtime": "workspace:^",
    "@jay-framework/stack-client-runtime": "workspace:^",
    "@jay-framework/stack-server-runtime": "workspace:^",
    "beautiful-mermaid": "^1.1.3",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@jay-framework/dev-environment": "workspace:^",
    "@jay-framework/jay-stack-cli": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.1"
  }
}
