{
  "name": "@jay-framework/design-system-validator",
  "version": "0.21.0",
  "type": "module",
  "description": "Design system validation plugin for Jay Framework — validates jay-html CSS against DESIGN.md tokens",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "files": [
    "dist",
    "plugin.yaml",
    "agent-kit"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./plugin.yaml": "./plugin.yaml"
  },
  "scripts": {
    "build": "npm run clean && npm run build:server && npm run build:types && npm run validate",
    "validate": "jay-stack-cli validate-plugin",
    "build:server": "vite build --ssr",
    "build:types": "tsup lib/index.ts --dts-only --format esm",
    "build:check-types": "tsc",
    "clean": "rimraf dist",
    "confirm": "npm run clean && npm run build && npm run test",
    "test": "vitest run"
  },
  "dependencies": {
    "@csstools/selector-specificity": "^5.0.0",
    "@jay-framework/compiler-shared": "workspace:^",
    "@jay-framework/stack-server-runtime": "workspace:^",
    "js-yaml": "^4.1.0",
    "postcss": "^8.5.6",
    "postcss-selector-parser": "^7.1.0"
  },
  "devDependencies": {
    "@jay-framework/dev-environment": "workspace:^",
    "@jay-framework/jay-stack-cli": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "node-html-parser": "^6.1.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.1"
  }
}
