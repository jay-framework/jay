<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-headfull"
            src="./header/header"
            contract="./header/header.jay-contract"
            names="header"></script>
    <script type="application/jay-data" contract="./page.jay-contract">
    </script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="section">
            <h2>Static Section</h2>
            <p>Some static content before the forEach</p>
        </div>
        <div class="section">
            <h2>Items</h2>
            <div forEach="items" trackBy="_id">
                <div class="card">
                    <strong>{name}</strong>
                    <jay:header itemId="{_id}" />
                </div>
            </div>
        </div>
        <button ref="addButton">Add Item</button>
    </div>
</body>
</html>
