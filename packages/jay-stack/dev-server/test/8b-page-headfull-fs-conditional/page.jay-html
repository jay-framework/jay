<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-headfull"
            src="./header/header"
            contract="./header/header.jay-contract"
            names="header"></script>
    <script type="application/jay-data" contract="./page.jay-contract">
    </script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <jay:header itemId="1" if="showWidget" />
        <p if="!showWidget">Widget hidden</p>
        <button ref="toggleButton">Toggle</button>
    </div>
</body>
</html>
