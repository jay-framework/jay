<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-headfull"
            src="./header/header"
            contract="./header/header.jay-contract"
            names="header"></script>
    <script type="application/jay-data" contract="./page.jay-contract">
    </script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="list" forEach="items" trackBy="_id">
            <jay:header itemId="{_id}" />
        </div>
    </div>
</body>
</html>
