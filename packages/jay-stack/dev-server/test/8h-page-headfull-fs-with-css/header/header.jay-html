<html>
<head>
    <script type="application/jay-data">
        data:
            label: string
            value: number
    </script>
    <style>
        .widget { border: 1px solid #ccc; padding: 8px; }
        .widget .label { font-weight: bold; }
    </style>
</head>
<body>
    <div class="widget">
        <span class="label">{label}</span>
        <span class="value">{value}</span>
        <button ref="increment">+1</button>
    </div>
</body>
</html>
