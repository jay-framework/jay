<!DOCTYPE html>
<html>
<head>
    <title>Page with Headless</title>
    <script type="application/jay-headless"
            plugin="test-headless"
            contract="headless"
            key="headless"></script>
    <script type="application/jay-data" contract="./page.jay-contract">
    </script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="widget">
            <span class="label">{headless.label}</span>
            <span class="count">{headless.count}</span>
            <button ref="headless.increment">+1</button>
        </div>
    </div>
</body>
</html>