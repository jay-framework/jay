<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-headless"
            plugin="test-widget"
            contract="widget"></script>
    <script type="application/jay-data" contract="./page.jay-contract">
    </script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="list" forEach="items" trackBy="_id">
            <jay:widget itemId="{_id}">
                <div class="widget">
                    <span class="label">{label}</span>
                    <span class="value">{value}</span>
                    <button ref="increment">+1</button>
                </div>
            </jay:widget>
        </div>
    </div>
</body>
</html>
