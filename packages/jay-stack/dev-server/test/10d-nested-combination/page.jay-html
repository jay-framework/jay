<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="category" forEach="categories" trackBy="_id">
            <h2>{name}</h2>
            <p class="details" if="showDetails">Details visible</p>
            <span class="active-badge" if="isActive">Active</span>
            <ul forEach="items" trackBy="_id">
                <li>{label}</li>
            </ul>
            <button ref="toggle-button">Toggle</button>
        </div>
    </div>
</body>
</html>
