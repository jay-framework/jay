<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
</head>
<body>
<div>
    <h1>{title}</h1>
    <div when-resolved="items">
        <p class="resolved">Items loaded</p>
    </div>
    <div when-loading="items">
        <p class="loading">Loading items...</p>
    </div>
</div>
</body>
</html>
