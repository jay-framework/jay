<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-headless"
            plugin="test-status"
            contract="status"
            key="status"></script>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <div class="banner" if="status.showBanner">
            <span class="banner-text">{status.bannerText}</span>
        </div>
        <p class="counter">Count: {status.counter}</p>
        <button ref="status.increment">+1</button>
    </div>
</body>
</html>
