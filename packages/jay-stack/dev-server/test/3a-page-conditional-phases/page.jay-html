<!DOCTYPE html>
<html>
<head>
    <script type="application/jay-data" contract="./page.jay-contract"></script>
</head>
<body>
    <div>
        <h1>{title}</h1>
        <span if="slowVisible" class="slow-true">Slow Visible</span>
        <span if="slowHidden" class="slow-false">Slow Hidden</span>
        <span if="fastVisible" class="fast-true">Fast Visible</span>
        <span if="fastHidden" class="fast-false">Fast Hidden</span>
        <span if="interactiveVisible" class="interactive-true">Interactive Visible</span>
        <span if="interactiveHidden" class="interactive-hidden">Interactive Hidden</span>
        <span if="slowVisible && fastVisible && interactiveVisible" class="mixed">Mixed</span>
        <button ref="toggle-button">Toggle</button>
    </div>
</body>
</html>
