name: Page
tags:
  - tag: title
    type: data
    dataType: string
    phase: slow
  - tag: slowItems
    type: sub-contract
    phase: slow
    repeated: true
    trackBy: _id
    tags:
      - tag: _id
        type: data
        dataType: string
      - tag: label
        type: data
        dataType: string
  - tag: fastItems
    type: sub-contract
    phase: fast
    repeated: true
    trackBy: _id
    tags:
      - tag: _id
        type: data
        dataType: string
      - tag: label
        type: data
        dataType: string
  - tag: fastMixedItems
    type: sub-contract
    phase: fast
    repeated: true
    trackBy: _id
    tags:
      - tag: _id
        type: data
        dataType: string
      - tag: label
        type: data
        dataType: string
        phase: fast
      - tag: count
        type: data
        dataType: number
        phase: fast+interactive
      - tag: increment
        type: interactive
        elementType: HTMLButtonElement
  - tag: interactiveItems
    type: sub-contract
    phase: fast+interactive
    repeated: true
    trackBy: _id
    tags:
      - tag: _id
        type: data
        dataType: string
      - tag: label
        type: data
        dataType: string
      - tag: count
        type: data
        dataType: number
      - tag: increment
        type: interactive
        elementType: HTMLButtonElement
  - tag: addButton
    type: interactive
    elementType: HTMLButtonElement
  - tag: removeButton
    type: interactive
    elementType: HTMLButtonElement
