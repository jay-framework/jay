<!DOCTYPE html>
<html lang="en">
<head>
  <script type="application/jay-data" contract="./page.jay-contract"></script>
  <style>
    .page { max-width: 960px; margin: 0 auto; padding: 40px 20px; }
    .page-title { font-size: 28px; font-weight: 700; margin: 0 0 24px; color: #1a1a1a; }
    .items-grid { display: flex; flex-direction: column; gap: 16px; }
    .item-card { background: #f8f8f8; border: 1px solid #e8e8e8; border-radius: 8px; padding: 20px; display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: inherit; }
    .item-name { font-size: 18px; font-weight: 600; margin: 0; }
    .item-price { font-size: 16px; color: #666666; }
  </style>
</head>
<body>
  <div class="page">
    <h1 class="page-title">{title}</h1>
    <div class="items-grid" forEach="items" trackBy="id">
      <a class="item-card" ref="itemLink">
        <h3 class="item-name">{name}</h3>
        <span class="item-price">{price}</span>
      </a>
    </div>
  </div>
</body>
</html>
