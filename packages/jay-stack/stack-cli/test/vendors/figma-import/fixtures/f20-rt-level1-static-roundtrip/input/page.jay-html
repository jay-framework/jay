<!DOCTYPE html>
<html lang="en">
<head>
  <script type="application/jay-data" contract="./page.jay-contract"></script>
  <style>
    .page { max-width: 960px; margin: 0 auto; padding: 40px 20px; }
    .hero { text-align: center; margin-bottom: 48px; }
    .hero-title { font-size: 36px; font-weight: 700; margin: 0 0 12px; color: #1a1a1a; }
    .hero-subtitle { font-size: 18px; color: #666666; margin: 0; }
    .card { background: #f8f8f8; border-radius: 8px; padding: 24px; display: flex; flex-direction: column; gap: 16px; }
    .card-title { font-size: 20px; font-weight: 600; margin: 0; }
    .card-description { font-size: 14px; color: #666666; margin: 0; }
    .site-footer { margin-top: 60px; padding-top: 24px; border-top: 1px solid #e8e8e8; text-align: center; color: #666666; font-size: 14px; }
  </style>
</head>
<body>
  <div class="page">
    <header class="hero">
      <h1 class="hero-title">Welcome</h1>
      <p class="hero-subtitle">A simple static page for roundtrip testing.</p>
    </header>
    <main class="card">
      <h2 class="card-title">Featured Item</h2>
      <p class="card-description">This is a description of the featured item.</p>
    </main>
    <footer class="site-footer">
      <p>Roundtrip Lab</p>
    </footer>
  </div>
</body>
</html>
