{
  "requiredTextBindings": [
    "title",
    "emptyMessage",
    "name",
    "price",
    "discountLabel"
  ],
  "requiredConditions": ["hasItems === false", "hasItems", "hasDiscount"],
  "requiredForEach": ["items"],
  "requiredTrackBy": ["id"],
  "requiredInlineOverrides": [
    { "selector": ".hero-banner", "property": "background-image" },
    { "selector": ".hero-banner", "property": "opacity" },
    { "selector": ".item-card", "property": "border-color" },
    { "selector": ".discount-badge", "property": "background-color" }
  ],
  "warningsMustNotContain": ["IMPORT_PARSE_FAILED", "TIER2_FALLBACK"]
}
