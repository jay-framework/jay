<html>
<head>
    <script type="application/jay-data">
data:
    title: string
    </script>
    <script type="application/jay-headless"
            plugin="test-widget"
            contract="test-widget"></script>
</head>
<body>
<div>
    <h1>{title}</h1>
    <jay:test-widget itemId="1">
        <span>{label}</span>
    </jay:test-widget>
</div>
</body>
</html>
