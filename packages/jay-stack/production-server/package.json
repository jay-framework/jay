{
  "name": "@jay-framework/production-server",
  "version": "0.19.2",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./serve": {
      "types": "./dist/serve-index.d.ts",
      "default": "./dist/serve-index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:types",
    "build:watch": "npm run build:js -- --watch & npm run build:types -- --watch",
    "build:js": "vite build",
    "build:types": "tsup lib/index.ts lib/serve-index.ts --dts-only --format esm",
    "build:check-types": "tsc",
    "clean": "rimraf dist",
    "confirm": "npm run clean && npm run build && npm run build:check-types && npm run test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jay-framework/compiler-jay-html": "workspace:^",
    "@jay-framework/compiler-jay-stack": "workspace:^",
    "@jay-framework/compiler-shared": "workspace:^",
    "@jay-framework/fullstack-component": "workspace:^",
    "@jay-framework/logger": "workspace:^",
    "@jay-framework/ssr-runtime": "workspace:^",
    "@jay-framework/stack-route-scanner": "workspace:^",
    "@jay-framework/stack-server-runtime": "workspace:^",
    "@jay-framework/view-state-merge": "workspace:^",
    "@jay-framework/vite-plugin": "workspace:^",
    "vite": "^5.0.11"
  },
  "devDependencies": {
    "@jay-framework/dev-environment": "workspace:^",
    "@types/node": "^22.15.21",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
