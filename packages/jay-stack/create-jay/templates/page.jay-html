<html lang="en">
  <head>
    <title>{{name}}</title>
    <meta name="description" content="A Jay Stack project">
    <script type="application/jay-data" contract="./page.jay-contract"></script>
    <link rel="stylesheet" href="../styles/theme.css" />
    <style>
      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        text-align: center;
        padding: 2rem;
      }
      .hero h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
      }
      .hero p {
        font-size: 1.25rem;
        color: #64748b;
        max-width: 600px;
      }
    </style>
  </head>
  <body>
    <main class="hero">
      <h1>{title}</h1>
      <p>{description}</p>
    </main>
  </body>
</html>
